# ── Project paths ──────────────────────────────────────────
# Absolute path to the project root (auto-detected if left empty)
PROJECT_ROOT=

# ── Data settings ──────────────────────────────────────────
# Category to use from WDC LSPC: computers | cameras | watches | shoes
WDC_CATEGORY=computers

# Training set size on HuggingFace:
#   small (~2k pairs) | medium (~4k) | large (~12k) | xlarge (~26k+)
WDC_TRAIN_SIZE=xlarge

# Random seed for all split/shuffle operations
RANDOM_SEED=42

# ── Model settings (used from Milestone 3 onwards) ─────────
# HuggingFace model name for the bi-encoder backbone
BIENCODER_MODEL=sentence-transformers/all-mpnet-base-v2

# Maximum token length for product text encoding
MAX_SEQ_LENGTH=128

# ── LLM settings (used from Milestone 4 onwards) ───────────
# OpenAI / Anthropic API key — add your key here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LLM model name for hard negative mining
LLM_MODEL=claude-3-5-haiku-20241022

# Number of hard negatives the LLM evaluates per anchor
LLM_TOPK_CANDIDATES=20
